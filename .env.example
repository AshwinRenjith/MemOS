# ============================================================
# MemoryOS — Environment Variables (.env.example)
# ============================================================
# Copy to .env and modify for local development:
#   cp .env.example .env
#
# NEVER commit the actual .env file!
# ============================================================

# --- Application ---
MEMORYOS_ENVIRONMENT=development
MEMORYOS_DEPLOYMENT_PROFILE=cloud
MEMORYOS_DEBUG=true
MEMORYOS_LOG_LEVEL=DEBUG

# --- Server ---
MEMORYOS_HOST=0.0.0.0
MEMORYOS_PORT=8000

# --- PostgreSQL ---
MEMORYOS_DB_HOST=localhost
MEMORYOS_DB_PORT=5432
MEMORYOS_DB_NAME=memoryos
MEMORYOS_DB_USER=memoryos_app
MEMORYOS_DB_PASSWORD=memoryos_dev_password

# --- Redis ---
MEMORYOS_REDIS_URL=redis://localhost:6379/0
MEMORYOS_REDIS_PASSWORD=memoryos_dev_password

# --- Qdrant ---
MEMORYOS_QDRANT_HOST=localhost
MEMORYOS_QDRANT_PORT=6333

# --- Kafka ---
MEMORYOS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Observability ---
MEMORYOS_OTLP_ENDPOINT=http://localhost:4317
MEMORYOS_TRACES_SAMPLE_RATE=1.0

# --- External LLM (Cloud profile) ---
# MEMORYOS_OPENAI_API_KEY=sk-your-key-here
MEMORYOS_EMBEDDING_MODEL=text-embedding-3-small

# --- JWT ---
MEMORYOS_JWT_SECRET_KEY=dev-secret-key-change-in-production

# --- Encryption ---
MEMORYOS_ENCRYPTION_KEY_SEED=dev-encryption-seed-change-in-production
